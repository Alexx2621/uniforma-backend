generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/**
 * ======================
 * TABLAS GENERALES
 * ======================
 */

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  productos   Producto[]
}

model Tela {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  productos   Producto[]
}

model Color {
  id        Int        @id @default(autoincrement())
  nombre    String
  codigoHex String?
  productos Producto[]
}

model Talla {
  id        Int        @id @default(autoincrement())
  nombre    String
  productos Producto[]
}

/**
 * ======================
 * PRODUCTOS
 * ======================
 */

model Producto {
  id       Int     @id @default(autoincrement())
  codigo   String  @unique
  nombre   String
  genero   String?
  tipo     String?
  precio   Float
  mermaPorcentaje Float @default(0)
  stockMax Int     @default(0)

  categoriaId Int?
  telaId      Int?
  colorId     Int?
  tallaId     Int?

  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  tela      Tela?      @relation(fields: [telaId], references: [id])
  color     Color?     @relation(fields: [colorId], references: [id])
  talla     Talla?     @relation(fields: [tallaId], references: [id])

  inventario              Inventario[]
  detalleVenta            DetalleVenta[]
  detalleIngreso          DetalleIngreso[]
  detallePedidoProduccion DetallePedidoProduccion[]
  detalleTraslado         DetalleTraslado[]
  imagenes                ImagenProducto[]
  consumoInsumos          ConsumoInsumo[]
  costosProduccion        CostosProduccion[]
  movimientosInventario   MovInventario[]
}

/**
 * ======================
 * CLIENTES
 * ======================
 */

model Cliente {
  id          Int     @id @default(autoincrement())
  nombre      String
  telefono    String?
  correo      String?
  direccion   String?
  tipoCliente String?

  ventas Venta[]
  pedidos PedidoProduccion[]
}

/**
 * ======================
 * VENTAS
 * ======================
 */

model Venta {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @default(now())
  clienteId     Int?
  clienteNombre String?
  clienteTelefono String?
  total         Float @default(0)
  metodoPago    String
  ubicacion     String?
  recargo       Float    @default(0)
  observaciones String?
  bodegaId      Int?
  vendedor      String?

  cliente Cliente?       @relation(fields: [clienteId], references: [id])
  bodega  Bodega?        @relation(fields: [bodegaId], references: [id])
  detalle DetalleVenta[]
  pagos   PagoVenta[]
}

model DetalleVenta {
  id         Int   @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Int
  precioUnit Float
  bordado    Float  @default(0)
  descuento  Float  @default(0)
  descripcion String? @default("")
  subtotal   Float

  venta    Venta    @relation(fields: [ventaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

model PagoVenta {
  id      Int      @id @default(autoincrement())
  ventaId Int
  metodo  String
  monto   Float
  referencia String?
  fecha   DateTime @default(now())

  venta Venta @relation(fields: [ventaId], references: [id])
}

/**
 * ======================
 * INVENTARIOS
 * ======================
 */

model Bodega {
  id             Int                 @id @default(autoincrement())
  nombre         String
  ubicacion      String?
  inventario     Inventario[]
  ingresos       IngresoInventario[]
  trasladosDesde Traslado[]          @relation("DesdeBodega")
  trasladosHacia Traslado[]          @relation("HaciaBodega")
  movimientos    MovInventario[]
  usuarios       Usuario[]
  pedidos        PedidoProduccion[]
  ventas         Venta[]
  correlativos   CorrelativoConfig[]
  unificadosProduccion ProduccionUnificado[]
}

model CorrelativoConfig {
  id              Int      @id @default(autoincrement())
  tipo            String
  scope           String   @unique
  nombre          String
  abreviatura     String
  siguienteNumero Int      @default(1)
  bodegaId        Int?
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  bodega Bodega? @relation(fields: [bodegaId], references: [id])

  @@index([tipo])
  @@index([bodegaId])
}

model ProduccionUnificado {
  id             Int      @id @default(autoincrement())
  scope          String
  firmaContenido String
  correlativo    String   @unique
  abreviatura    String
  numero         Int
  nombre         String
  bodegaId       Int?
  resumen        Json?
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  bodega Bodega? @relation(fields: [bodegaId], references: [id])
  pedidos ProduccionUnificadoPedido[]

  @@unique([scope, firmaContenido])
  @@index([scope, creadoEn])
  @@index([bodegaId])
}

model ProduccionUnificadoPedido {
  produccionUnificadoId Int
  pedidoId              Int
  creadoEn              DateTime @default(now())

  produccionUnificado ProduccionUnificado @relation(fields: [produccionUnificadoId], references: [id])
  pedido              PedidoProduccion    @relation(fields: [pedidoId], references: [id])

  @@id([produccionUnificadoId, pedidoId])
  @@index([pedidoId])
}

model Inventario {
  id         Int @id @default(autoincrement())
  bodegaId   Int
  productoId Int
  stock      Int @default(0)

  bodega   Bodega   @relation(fields: [bodegaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([bodegaId, productoId])
}

/**
 * ======================
 * INGRESOS A BODEGA
 * ======================
 */

model IngresoInventario {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @default(now())
  bodegaId      Int
  observaciones String?
  responsable   String?

  bodega  Bodega           @relation(fields: [bodegaId], references: [id])
  detalle DetalleIngreso[]
}

model DetalleIngreso {
  id         Int   @id @default(autoincrement())
  ingresoId  Int
  productoId Int
  cantidad   Int

  ingreso  IngresoInventario @relation(fields: [ingresoId], references: [id])
  producto Producto          @relation(fields: [productoId], references: [id])
}

/**
 * ======================
 * TRASLADOS
 * ======================
 */

model Traslado {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @default(now())
  desdeBodegaId Int
  haciaBodegaId Int
  observaciones String?

  desdeBodega Bodega @relation("DesdeBodega", fields: [desdeBodegaId], references: [id])
  haciaBodega Bodega @relation("HaciaBodega", fields: [haciaBodegaId], references: [id])

  detalle DetalleTraslado[]
}

model DetalleTraslado {
  id         Int @id @default(autoincrement())
  trasladoId Int
  productoId Int
  cantidad   Int

  traslado Traslado @relation(fields: [trasladoId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

/**
 * ======================
 * INSUMOS
 * ======================
 */

model Insumo {
  id            Int    @id @default(autoincrement())
  nombre        String
  tipo          String
  unidad        String
  stock         Float  @default(0)
  stockMin      Float  @default(0)
  costoPromedio Float  @default(0)

  consumoProductos ConsumoInsumo[]
  mermas           MermaProduccion[]
  ordenesCompra    DetalleOrdenCompra[]
}

model ConsumoInsumo {
  id                Int   @id @default(autoincrement())
  productoId        Int
  insumoId          Int
  cantidadPorUnidad Float

  producto Producto @relation(fields: [productoId], references: [id])
  insumo   Insumo   @relation(fields: [insumoId], references: [id])
}

/**
 * ======================
 * PRODUCCIÓN
 * ======================
 */

model PedidoProduccion {
  id            Int      @id @default(autoincrement())
  folio         String?  @unique
  fecha         DateTime @default(now())
  estado        String   @default("pendiente")
  solicitadoPor String?
  observaciones String?
  clienteId     Int?
  clienteNombre String?
  clienteTelefono String?
  bodegaId      Int?
  totalEstimado Float    @default(0)
  anticipo      Float    @default(0)
  saldoPendiente Float   @default(0)
  recargo       Float    @default(0)
  porcentajeRecargo Float @default(0)
  envio         Float    @default(0)
  metodoPago    String?  // método del anticipo

  cliente Cliente? @relation(fields: [clienteId], references: [id])
  bodega  Bodega?  @relation(fields: [bodegaId], references: [id])
  detalle DetallePedidoProduccion[]
  avances ProduccionAvance[]
  mermas  MermaProduccion[]
  pagos   PagoPedido[]
  unificaciones ProduccionUnificadoPedido[]
}

model DetallePedidoProduccion {
  id         Int @id @default(autoincrement())
  pedidoId   Int
  productoId Int
  cantidad   Int
  precioUnit Float @default(0)
  bordado    Float @default(0)
  estiloEspecial Boolean @default(false)
  estiloEspecialMonto Float @default(0)
  descuento  Float @default(0)
  descripcion String? @default("")

  pedido   PedidoProduccion @relation(fields: [pedidoId], references: [id])
  producto Producto         @relation(fields: [productoId], references: [id])
}

model PagoPedido {
  id       Int      @id @default(autoincrement())
  pedidoId Int
  monto    Float
  metodo   String
  tipo     String   @default("anticipo") // anticipo o saldo
  fecha    DateTime @default(now())
  recargo  Float    @default(0)
  porcentajeRecargo Float @default(0)
  referencia String?

  pedido PedidoProduccion @relation(fields: [pedidoId], references: [id])
}

model ProduccionAvance {
  id          Int      @id @default(autoincrement())
  pedidoId    Int
  fase        String
  cantidad    Int
  fecha       DateTime @default(now())
  responsable String?

  pedido PedidoProduccion @relation(fields: [pedidoId], references: [id])
}

model CostosProduccion {
  id             Int      @id @default(autoincrement())
  productoId     Int
  costoInsumos   Float
  costoManoObra  Float
  costoOperativo Float
  costoTotal     Float
  fecha          DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
}

model MermaProduccion {
  id       Int      @id @default(autoincrement())
  insumoId Int?
  pedidoId Int
  cantidad Float
  motivo   String?
  fecha    DateTime @default(now())

  insumo Insumo?           @relation(fields: [insumoId], references: [id])
  pedido PedidoProduccion @relation(fields: [pedidoId], references: [id])
}

/**
 * ======================
 * LOGS
 * ======================
 */

 model LogAcceso {
  id        Int      @id @default(autoincrement())
  usuario   String?
  endpoint  String
  metodo    String
  ip        String?
  fecha     DateTime @default(now())
  resultado String?
}

model MovInventario {
  id         Int      @id @default(autoincrement())
  bodegaId   Int
  productoId Int
  tipo       String
  cantidad   Int
  fecha      DateTime @default(now())
  referencia String?

  bodega   Bodega   @relation(fields: [bodegaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

/**
 * ======================
 * ORDENES DE COMPRA
 * ======================
 */

model Proveedor {
  id        Int     @id @default(autoincrement())
  nombre    String
  contacto  String?
  telefono  String?
  correo    String?
  direccion String?
  tipo      String?

  ordenes OrdenCompra[]
}

model OrdenCompra {
  id            Int      @id @default(autoincrement())
  fecha         DateTime @default(now())
  proveedorId   Int
  estado        String   @default("pendiente")
  total         Float
  observaciones String?

  proveedor Proveedor            @relation(fields: [proveedorId], references: [id])
  detalle   DetalleOrdenCompra[]
}

model DetalleOrdenCompra {
  id        Int   @id @default(autoincrement())
  ordenId   Int
  insumoId  Int
  cantidad  Float
  costoUnit Float
  subtotal  Float

  orden  OrdenCompra @relation(fields: [ordenId], references: [id])
  insumo Insumo      @relation(fields: [insumoId], references: [id])
}

/**
 * ======================
 * ROLES
 * ======================
 */

model Rol {
  id          Int          @id @default(autoincrement())
  nombre      String
  descripcion String?
  usuarios    Usuario[]
  permisos    RolPermiso[]
  alertas     AlertaInterna[]
}

model Permiso {
  id          Int          @id @default(autoincrement())
  nombre      String
  descripcion String?
  roles       RolPermiso[]
}

model RolPermiso {
  id        Int @id @default(autoincrement())
  rolId     Int
  permisoId Int

  rol     Rol     @relation(fields: [rolId], references: [id])
  permiso Permiso @relation(fields: [permisoId], references: [id])
}

model Usuario {
  id              Int      @id @default(autoincrement())
  nombre          String
  primerNombre    String?
  segundoNombre   String?
  primerApellido  String?
  segundoApellido String?
  usuario         String   @unique
  usuarioCorrelativo String?  @unique
  correo          String?  @unique
  telefono        String?
  dpi             String?  @unique
  direccion       String?
  fechaNacimiento DateTime?
  fotoUrl         String?  @db.MediumText
  password        String
  rolId           Int
  activo          Boolean  @default(true)

  rol Rol @relation(fields: [rolId], references: [id])
  bodegaId Int?
  bodega   Bodega? @relation(fields: [bodegaId], references: [id])
  alertas  AlertaInterna[]
  correlativoContadores UsuarioCorrelativoContador[]
  documentosGenerados DocumentoGenerado[]
  postventaRegistros CambioDevolucion[]
}

model UsuarioCorrelativoContador {
  id              Int      @id @default(autoincrement())
  usuarioId       Int
  operacion       String
  prefijo         String
  codigoUsuario   String
  siguienteNumero Int      @default(1)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, operacion])
  @@index([operacion])
}

model AlertaInterna {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  rolId      Int?
  tipo       String
  titulo     String
  mensaje    String   @db.MediumText
  payload    String?  @db.MediumText
  leida      Boolean  @default(false)
  creadaEn   DateTime @default(now())
  leidaEn    DateTime?

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  rol     Rol?    @relation(fields: [rolId], references: [id])

  @@index([usuarioId, leida, creadaEn])
  @@index([rolId, creadaEn])
}

model DocumentoGenerado {
  id             Int      @id @default(autoincrement())
  tipo           String
  correlativo    String   @unique
  titulo         String?
  data           Json
  usuarioId      Int
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([tipo, creadoEn])
  @@index([usuarioId, creadoEn])
}

model CambioDevolucion {
  id                  Int      @id @default(autoincrement())
  folio               String   @unique
  tipo                String
  fecha               DateTime @default(now())
  clienteNombre       String
  clienteTelefono     String?
  documentoReferencia String?
  motivo              String
  estado              String   @default("pendiente")
  resolucion          String?
  monto               Float    @default(0)
  observaciones       String?  @db.MediumText
  detalle             Json
  usuarioId           Int?
  creadoEn            DateTime @default(now())
  actualizadoEn       DateTime @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([tipo, fecha])
  @@index([estado, fecha])
  @@index([usuarioId, fecha])
}

/**
 * ======================
 * CONFIGURACIÓN
 * ======================
 */

model NotificacionConfig {
  id                 Int      @id @default(1)
  emailTo            String?  @default("")
  whatsappTo         String?  @default("")
  stockThreshold     Int      @default(5)
  highSaleThreshold  Int      @default(1000)
  disabledPaths      Json?
  productionInternalMode Boolean @default(false)
  userDisabledPaths  Json?
  productMassConfig  Json?
  pedidoAlertRoleIds Json?
  crossStoreRoleIds  Json?
  unifyOrderRoleIds  Json?
  
  // Configuración SMTP para correos
  smtpHost           String?  @default("smtp.gmail.com")
  smtpPort           Int      @default(587)
  smtpUser           String?
  smtpPass           String?
  smtpFrom           String?  @default("noreply@uniforma.com")

  // Configuración de Resend para envío de correos
  resendEnabled      Boolean  @default(false)
  resendApiKey       String?
  resendFrom         String?  @default("noreply@uniforma.com")
  resendTemplateId   String?
  
  // Configuración de reportes automáticos
  reportesConfig     Json?    // Array de configuraciones de reportes
  sessionInvalidatedAt DateTime?
  
  updatedAt          DateTime @updatedAt
}

/**
 * ======================
 * IMÁGENES
 * ======================
 */

model ImagenProducto {
  id          Int     @id @default(autoincrement())
  productoId  Int
  url         String
  descripcion String?
  esPrincipal Boolean @default(false)

  producto Producto @relation(fields: [productoId], references: [id])
}
